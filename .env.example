# Copier en .env et remplir les valeurs
# NE PAS committer ce fichier avec les vraies clés

# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-api03-...

# URL Redis — Upstash recommandé (format : redis://default:PASSWORD@HOST:PORT)
REDIS_URL=redis://localhost:6379

# URL du front (pour CORS)
CLIENT_URL=http://localhost:5173

# Port (Railway l'injecte automatiquement en prod)
PORT=3001
